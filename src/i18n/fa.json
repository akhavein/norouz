{
  "title": "\u0634\u0645\u0627\u0631\u0634 \u0645\u0639\u06a9\u0648\u0633 \u0646\u0648\u0631\u0648\u0632",
  "subtitle": "\u0646\u0648\u0631\u0648\u0632",
  "loading": "\u2026\u062f\u0631 \u062d\u0627\u0644 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc",
  "days": "\u0631\u0648\u0632",
  "hours": "\u0633\u0627\u0639\u062a",
  "minutes": "\u062f\u0642\u06cc\u0642\u0647",
