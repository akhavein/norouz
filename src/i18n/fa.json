  "norouz_mobarak": "!\u0646\u0648\u0631\u0648\u0632 \u0645\u0628\u0627\u0631\u06a9",
  "see_you": "!\u0633\u0627\u0644 \u062f\u06cc\u06af\u0631 \u0645\u06cc\u200c\u0628\u06cc\u0646\u0645\u062a\u0648\u0646",
  "blurb": "\u0646\u0648\u0631\u0648\u0632 \u0646\u062e\u0633\u062a\u06cc\u0646 \u0631\u0648\u0632 \u0628\u0647\u0627\u0631 \u0648 \u0622\u063a\u0627\u0632 \u0633\u0627\u0644 \u0646\u0648 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0627\u0633\u062a \u06a9\u0647 \u062f\u0631\u0633\u062a \u062f\u0631 \u0644\u062d\u0638\u0647 \u062a\u062d\u0648\u06cc\u0644 \u0633\u0627\u0644\u060c \u0647\u0645\u200c\u0632\u0645\u0627\u0646 \u0628\u0627 \u0627\u0639\u062a\u062f\u0627\u0644 \u0628\u0647\u0627\u0631\u06cc\u060c \u062c\u0634\u0646 \u06af\u0631\u0641\u062a\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f.",
  "footer": "\u0633\u0627\u062e\u062a\u0647 \u0634\u062f\u0647 \u0628\u0627 \u2661 \u0628\u0631\u0627\u06cc \u0646\u0648\u0631\u0648\u0632",
  "play": "\u0645\u0648\u0633\u06cc\u0642\u06cc \u062a\u062d\u0648\u06cc\u0644",
  "pause": "\u062a\u0648\u0642\u0641",
  "countdown_label": "\u0634\u0645\u0627\u0631\u0634 \u0645\u0639\u06a9\u0648\u0633 \u062a\u0627 \u0646\u0648\u0631\u0648\u0632",
  "switch_to_light": "\u062a\u063a\u06cc\u06cc\u0631 \u0628\u0647 \u062d\u0627\u0644\u062a \u0631\u0648\u0634\u0646",
  "switch_to_dark": "\u062a\u063a\u06cc\u06cc\u0631 \u0628\u0647 \u062d\u0627\u0644\u062a \u062a\u0627\u0631\u06cc\u06a9",
  "haftsin_title": "\u0647\u0641\u062a\u200c\u0633\u06cc\u0646",
  "haftsin_sabzeh": "\u0633\u0628\u0632\u0647 \u0646\u0645\u0627\u062f \u062a\u0627\u0632\u06af\u06cc\u060c \u0631\u0648\u06cc\u0634 \u0648 \u0632\u0646\u062f\u06af\u06cc \u062f\u0648\u0628\u0627\u0631\u0647 \u0627\u0633\u062a \u0648 \u06cc\u0627\u062f\u0622\u0648\u0631 \u0628\u06cc\u062f\u0627\u0631\u06cc \u0637\u0628\u06cc\u0639\u062a \u067e\u0633 \u0627\u0632 \u0632\u0645\u0633\u062a\u0627\u0646. \u062f\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u06af\u0646\u062f\u0645\u060c \u062c\u0648 \u06cc\u0627 \u0639\u062f\u0633 \u0631\u0627 \u0647\u0641\u062a\u0647\u200c\u0647\u0627 \u067e\u06cc\u0634 \u0627\u0632 \u0646\u0648\u0631\u0648\u0632 \u0645\u06cc\u200c\u06a9\u0627\u0631\u0646\u062f \u062a\u0627 \u0633\u0628\u0632\u0647\u200c\u0627\u06cc \u0633\u0631\u0633\u0628\u0632 \u0631\u0648\u06cc \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u062c\u0627\u06cc \u0628\u06af\u06cc\u0631\u062f. \u062f\u0631 \u0631\u0648\u0632 \u0633\u06cc\u0632\u062f\u0647\u200c\u0628\u062f\u0631\u060c \u0633\u0628\u0632\u0647 \u0631\u0627 \u0628\u0647 \u0622\u0628 \u0631\u0648\u0627\u0646 \u0645\u06cc\u200c\u0633\u067e\u0627\u0631\u0646\u062f \u062a\u0627 \u063a\u0645\u200c\u0647\u0627\u06cc \u0633\u0627\u0644 \u06a9\u0647\u0646\u0647 \u0631\u0627 \u0628\u0627 \u062e\u0648\u062f \u0628\u0628\u0631\u062f.",
  "haftsin_sib": "\u0633\u06cc\u0628 \u0646\u0645\u0627\u062f \u0633\u0644\u0627\u0645\u062a\u06cc \u0648 \u0632\u06cc\u0628\u0627\u06cc\u06cc \u0627\u0633\u062a \u0648 \u062d\u0636\u0648\u0631\u0634 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u0622\u0631\u0632\u0648\u06cc \u062a\u0646\u062f\u0631\u0633\u062a\u06cc \u0628\u0631\u0627\u06cc \u0627\u0639\u0636\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0631\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f. \u062f\u0631 \u0641\u0631\u0647\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u06cc\u060c \u0633\u06cc\u0628 \u0633\u0631\u062e \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0634\u0627\u062f\u0627\u0628\u06cc \u0648 \u0633\u0631\u0632\u0646\u062f\u06af\u06cc \u0627\u0633\u062a \u0648 \u0627\u0632 \u062f\u06cc\u0631\u0628\u0627\u0632 \u0628\u0627 \u0633\u0644\u0627\u0645\u062a \u062c\u0633\u0645 \u0648 \u0631\u0648\u062d \u067e\u06cc\u0648\u0646\u062f \u062f\u0627\u0634\u062a\u0647.",
  "haftsin_sir": "\u0633\u06cc\u0631 \u0646\u0645\u0627\u062f \u0633\u0644\u0627\u0645\u062a\u06cc\u060c \u062f\u0631\u0645\u0627\u0646 \u0648 \u062f\u0648\u0631 \u0634\u062f\u0646 \u0628\u062f\u06cc\u200c\u0647\u0627\u0633\u062a. \u062f\u0631 \u0628\u0627\u0648\u0631\u0647\u0627\u06cc \u06a9\u0647\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0648 \u0632\u0631\u062a\u0634\u062a\u06cc\u060c \u0633\u06cc\u0631 \u062f\u0627\u0641\u0639 \u0628\u06cc\u0645\u0627\u0631\u06cc \u0648 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0627\u0647\u0631\u06cc\u0645\u0646\u06cc \u0628\u0647 \u0634\u0645\u0627\u0631 \u0645\u06cc\u200c\u0631\u0641\u062a. \u062c\u0627\u06cc \u062f\u0627\u062f\u0646 \u0633\u06cc\u0631 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646\u060c \u0622\u0631\u0632\u0648\u06cc \u062a\u0646\u062f\u0631\u0633\u062a\u06cc \u0648 \u067e\u0627\u06a9\u06cc \u0628\u0631\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u062f\u0631 \u0633\u0627\u0644 \u0646\u0648 \u0627\u0633\u062a.",
  "haftsin_senjed": "\u0633\u0646\u062c\u062f \u0646\u0645\u0627\u062f \u0639\u0634\u0642 \u0648 \u062e\u0631\u062f \u0627\u0633\u062a. \u062f\u0631 \u0641\u0631\u0647\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u06cc\u060c \u0627\u06cc\u0646 \u0645\u06cc\u0648\u0647 \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u062f\u0644\u0628\u0633\u062a\u06af\u06cc \u0648 \u0645\u0647\u0631\u0648\u0631\u0632\u06cc \u0645\u06cc\u0627\u0646 \u0627\u0639\u0636\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0627\u0633\u062a \u0648 \u0628\u0627\u0648\u0631 \u0628\u0631 \u0627\u06cc\u0646 \u0628\u0648\u062f\u0647 \u06a9\u0647 \u062e\u0648\u0631\u062f\u0646 \u0622\u0646 \u0645\u0647\u0631 \u0648 \u0645\u062d\u0628\u062a \u0631\u0627 \u062f\u0631 \u062f\u0644 \u0628\u06cc\u062f\u0627\u0631 \u0645\u06cc\u200c\u06a9\u0646\u062f. \u0647\u0645\u0686\u0646\u06cc\u0646 \u0633\u0646\u062c\u062f \u0627\u0632 \u062f\u06cc\u0631\u0628\u0627\u0632 \u062f\u0631 \u0637\u0628 \u0633\u0646\u062a\u06cc \u0628\u0631\u0627\u06cc \u062a\u0642\u0648\u06cc\u062a \u062d\u0627\u0641\u0638\u0647 \u0648 \u0630\u0647\u0646 \u0628\u0647 \u06a9\u0627\u0631 \u0645\u06cc\u200c\u0631\u0641\u062a\u0647 \u0648 \u0646\u0645\u0627\u062f\u06cc \u0627\u0632 \u0641\u0631\u0632\u0627\u0646\u06af\u06cc \u0646\u06cc\u0632 \u0647\u0633\u062a.",
  "haftsin_samanu": "\u0633\u0645\u0646\u0648 \u0627\u0632 \u062c\u0648\u0627\u0646\u0647\u200c\u06cc \u06af\u0646\u062f\u0645 \u062a\u0647\u06cc\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f \u0648 \u0646\u0645\u0627\u062f \u062a\u0648\u0627\u0646\u06af\u0631\u06cc\u060c \u0628\u0631\u06a9\u062a \u0648 \u0628\u0627\u0631\u0648\u0631\u06cc \u0627\u0633\u062a. \u067e\u062e\u062a\u0646 \u0633\u0645\u0646\u0648 \u0633\u0627\u0639\u062a\u200c\u0647\u0627 \u0648\u0642\u062a \u0648 \u0635\u0628\u0631 \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f \u0648 \u0628\u0647 \u0647\u0645\u06cc\u0646 \u062f\u0644\u06cc\u0644 \u0646\u0645\u0627\u062f\u06cc \u0627\u0632 \u0634\u06a9\u06cc\u0628\u0627\u06cc\u06cc \u0648 \u067e\u0627\u062f\u0627\u0634 \u0634\u06cc\u0631\u06cc\u0646 \u062a\u0644\u0627\u0634 \u0646\u06cc\u0632 \u0647\u0633\u062a. \u0628\u0647\u200c\u0637\u0648\u0631 \u0633\u0646\u062a\u06cc\u060c \u0632\u0646\u0627\u0646 \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0648 \u0647\u0645\u0633\u0627\u06cc\u06af\u0627\u0646 \u062f\u0648\u0631 \u0647\u0645 \u062c\u0645\u0639 \u0645\u06cc\u200c\u0634\u0648\u0646\u062f \u0648 \u0628\u0627 \u0647\u0645\u200c\u0632\u062f\u0646 \u0633\u0645\u0646\u0648\u060c \u0631\u0648\u062d \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0648 \u06cc\u06a9\u062f\u0644\u06cc \u0631\u0627 \u0632\u0646\u062f\u0647 \u0646\u06af\u0647 \u0645\u06cc\u200c\u062f\u0627\u0631\u0646\u062f.",
  "haftsin_somaq": "\u0633\u0645\u0627\u0642 \u0628\u0627 \u0631\u0646\u06af \u0633\u0631\u062e\u200c\u0641\u0627\u0645 \u062e\u0648\u062f \u06cc\u0627\u062f\u0622\u0648\u0631 \u0637\u0644\u0648\u0639 \u062e\u0648\u0631\u0634\u06cc\u062f \u0648 \u067e\u06cc\u0631\u0648\u0632\u06cc \u0646\u0648\u0631 \u0628\u0631 \u062a\u0627\u0631\u06cc\u06a9\u06cc \u0627\u0633\u062a. \u0627\u06cc\u0646 \u0627\u062f\u0648\u06cc\u0647 \u0646\u0645\u0627\u062f \u0635\u0628\u0631 \u0648 \u0635\u0628\u0648\u0631\u06cc \u062f\u0631 \u0628\u0631\u0627\u0628\u0631 \u0633\u062e\u062a\u06cc\u200c\u0647\u0627 \u0648 \u0627\u0645\u06cc\u062f \u0628\u0647 \u0641\u0631\u0627 \u0631\u0633\u06cc\u062f\u0646 \u0631\u0648\u0632\u0647\u0627\u06cc \u0628\u0647\u062a\u0631 \u0627\u0633\u062a. \u062d\u0636\u0648\u0631 \u0633\u0645\u0627\u0642 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u067e\u06cc\u0627\u0645\u200c\u0622\u0648\u0631 \u0634\u06a9\u06cc\u0628\u0627\u06cc\u06cc \u0648 \u0627\u0645\u06cc\u062f\u0648\u0627\u0631\u06cc \u062f\u0631 \u0622\u063a\u0627\u0632 \u0633\u0627\u0644 \u0646\u0648 \u0627\u0633\u062a.",
  "haftsin_serkeh": "\u0633\u0631\u06a9\u0647 \u0646\u0645\u0627\u062f \u0635\u0628\u0631\u060c \u0628\u0631\u062f\u0628\u0627\u0631\u06cc \u0648 \u062e\u0631\u062f\u0645\u0646\u062f\u06cc \u0646\u0627\u0634\u06cc \u0627\u0632 \u06af\u0630\u0631 \u0632\u0645\u0627\u0646 \u0627\u0633\u062a. \u0647\u0645\u0627\u0646\u200c\u0637\u0648\u0631 \u06a9\u0647 \u0633\u0631\u06a9\u0647 \u0637\u06cc \u0641\u0631\u0622\u06cc\u0646\u062f\u06cc \u0637\u0648\u0644\u0627\u0646\u06cc \u0633\u0627\u062e\u062a\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f\u060c \u06cc\u0627\u062f\u0622\u0648\u0631 \u0622\u0646 \u0627\u0633\u062a \u06a9\u0647 \u0634\u06a9\u06cc\u0628\u0627\u06cc\u06cc \u0648 \u067e\u0630\u06cc\u0631\u0634 \u0633\u062e\u062a\u06cc\u200c\u0647\u0627\u060c \u0627\u0646\u0633\u0627\u0646 \u0631\u0627 \u0628\u0647 \u067e\u062e\u062a\u06af\u06cc \u0648 \u0641\u0631\u0632\u0627\u0646\u06af\u06cc \u0645\u06cc\u200c\u0631\u0633\u0627\u0646\u062f. \u0633\u0631\u06a9\u0647 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0631\u0636\u0627\u06cc\u062a \u0648 \u067e\u0630\u06cc\u0631\u0634 \u0641\u0631\u0627\u0632 \u0648 \u0646\u0634\u06cc\u0628\u200c\u0647\u0627\u06cc \u0632\u0646\u062f\u06af\u06cc \u0627\u0633\u062a.",
  "haftsin_extra_title": "\u062f\u06cc\u06af\u0631 \u0627\u0642\u0644\u0627\u0645 \u0633\u0641\u0631\u0647 \u0646\u0648\u0631\u0648\u0632",
  "haftsin_ayeneh": "\u0622\u06cc\u0646\u0647 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u0646\u0645\u0627\u062f \u0631\u0648\u0634\u0646\u0627\u06cc\u06cc\u060c \u067e\u0627\u06a9\u06cc \u0648 \u062e\u0648\u062f\u0634\u0646\u0627\u0633\u06cc \u0627\u0633\u062a. \u062f\u0631 \u0644\u062d\u0638\u0647\u200c\u06cc \u062a\u062d\u0648\u06cc\u0644 \u0633\u0627\u0644 \u0646\u0648\u060c \u0646\u06af\u0627\u0647 \u06a9\u0631\u062f\u0646 \u0628\u0647 \u0622\u06cc\u0646\u0647 \u06cc\u0627\u062f\u0622\u0648\u0631 \u0622\u0646 \u0627\u0633\u062a \u06a9\u0647 \u0633\u0627\u0644 \u0631\u0627 \u0628\u0627 \u0646\u06cc\u062a \u067e\u0627\u06a9 \u0648 \u062f\u0644\u06cc \u0631\u0648\u0634\u0646 \u0622\u063a\u0627\u0632 \u06a9\u0646\u06cc\u0645. \u0622\u06cc\u0646\u0647 \u062f\u0631 \u0641\u0631\u0647\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u06cc \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0635\u062f\u0627\u0642\u062a\u060c \u0628\u0627\u0632\u062a\u0627\u0628 \u062d\u0642\u06cc\u0642\u062a \u0648 \u0627\u0645\u06cc\u062f \u0628\u0647 \u0622\u06cc\u0646\u062f\u0647\u200c\u0627\u06cc \u062f\u0631\u062e\u0634\u0627\u0646 \u0628\u0648\u062f\u0647 \u0627\u0633\u062a.",
  "haftsin_mahi": "\u0645\u0627\u0647\u06cc \u0642\u0631\u0645\u0632 \u0646\u0645\u0627\u062f \u0632\u0646\u062f\u06af\u06cc\u060c \u062a\u062d\u0631\u06a9 \u0648 \u0633\u0631\u0632\u0646\u062f\u06af\u06cc \u0627\u0633\u062a. \u0631\u0646\u06af \u0633\u0631\u062e \u0622\u0646 \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0634\u0627\u062f\u06cc\u060c \u0645\u0647\u0631 \u0648 \u0628\u0631\u06a9\u062a \u0627\u0633\u062a \u0648 \u062d\u0631\u06a9\u062a \u0628\u06cc\u200c\u0648\u0642\u0641\u0647\u200c\u0627\u0634 \u062f\u0631 \u062a\u0646\u06af \u0622\u0628\u060c \u0686\u0631\u062e\u0634 \u0633\u0627\u0644 \u0648 \u062c\u0631\u06cc\u0627\u0646 \u0632\u0646\u062f\u06af\u06cc \u0631\u0627 \u0628\u0647 \u062a\u0635\u0648\u06cc\u0631 \u0645\u06cc\u200c\u06a9\u0634\u062f. \u062a\u0645\u0627\u0634\u0627\u06cc \u0645\u0627\u0647\u06cc \u062f\u0631 \u0644\u062d\u0638\u0647\u200c\u06cc \u062a\u062d\u0648\u06cc\u0644\u060c \u0646\u0648\u06cc\u062f\u0628\u062e\u0634 \u0646\u0634\u0627\u0637 \u0648 \u0641\u0631\u0627\u0648\u0627\u0646\u06cc \u062f\u0631 \u0633\u0627\u0644 \u0646\u0648 \u0627\u0633\u062a.",
  "haftsin_sham": "\u0634\u0645\u0639 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u0646\u0645\u0627\u062f \u0631\u0648\u0634\u0646\u0627\u06cc\u06cc\u060c \u06af\u0631\u0645\u0627 \u0648 \u0634\u0627\u062f\u0645\u0627\u0646\u06cc \u0627\u0633\u062a. \u0622\u062a\u0634 \u0648 \u0646\u0648\u0631 \u062f\u0631 \u0641\u0631\u0647\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u06cc \u0648 \u0622\u06cc\u06cc\u0646 \u0632\u0631\u062a\u0634\u062a\u06cc \u062c\u0627\u06cc\u06af\u0627\u0647 \u0648\u06cc\u0698\u0647\u200c\u0627\u06cc \u062f\u0627\u0631\u0646\u062f \u0648 \u0647\u0631 \u0634\u0645\u0639 \u0627\u0641\u0631\u0648\u062e\u062a\u0647\u060c \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0641\u0631\u0648\u063a \u0632\u0646\u062f\u06af\u06cc \u0648 \u0627\u0645\u06cc\u062f \u0628\u0647 \u0622\u06cc\u0646\u062f\u0647 \u0627\u0633\u062a. \u0634\u0645\u0639\u200c\u0647\u0627 \u062f\u0631 \u06a9\u0646\u0627\u0631 \u0622\u06cc\u0646\u0647 \u0642\u0631\u0627\u0631 \u0645\u06cc\u200c\u06af\u06cc\u0631\u0646\u062f \u0648 \u0646\u0648\u0631\u0634\u0627\u0646 \u0628\u0627\u0632\u062a\u0627\u0628\u06cc\u062f\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f \u062a\u0627 \u0633\u0641\u0631\u0647 \u0631\u0627 \u0633\u0631\u0634\u0627\u0631 \u0627\u0632 \u0631\u0648\u0634\u0646\u0627\u06cc\u06cc \u0648 \u0628\u0631\u06a9\u062a \u06a9\u0646\u062f.",
  "haftsin_tokhmmorgh": "\u062a\u062e\u0645\u200c\u0645\u0631\u063a \u0631\u0646\u06af\u06cc \u0646\u0645\u0627\u062f \u0628\u0627\u0631\u0648\u0631\u06cc\u060c \u0622\u0641\u0631\u06cc\u0646\u0634 \u0648 \u0632\u0627\u06cc\u0634 \u0632\u0646\u062f\u06af\u06cc \u062a\u0627\u0632\u0647 \u0627\u0633\u062a. \u0647\u0631 \u062a\u062e\u0645\u200c\u0645\u0631\u063a \u0631\u0646\u06af\u200c\u0634\u062f\u0647 \u0646\u0634\u0627\u0646\u0647\u200c\u06cc \u0627\u0645\u06cc\u062f \u0628\u0647 \u0634\u0631\u0648\u0639\u06cc \u0646\u0648 \u0648 \u062a\u062f\u0627\u0648\u0645 \u0646\u0633\u0644\u200c\u0647\u0627\u0633\u062a. \u0627\u06cc\u0646 \u0633\u0646\u062a \u06a9\u0647\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0628\u0627 \u0631\u06cc\u0634\u0647 \u062f\u0631 \u0622\u06cc\u06cc\u0646\u200c\u0647\u0627\u06cc \u0628\u0627\u0633\u062a\u0627\u0646\u06cc\u060c \u0646\u06cc\u0631\u0648\u06cc \u0632\u0627\u06cc\u0646\u062f\u0647\u200c\u06cc \u0637\u0628\u06cc\u0639\u062a \u0648 \u0646\u0648\u06cc\u062f \u0628\u0647\u0627\u0631 \u0631\u0627 \u06af\u0631\u0627\u0645\u06cc \u0645\u06cc\u200c\u062f\u0627\u0631\u062f.",
  "haftsin_sekkeh": "\u0633\u06a9\u0647 \u0628\u0631 \u0633\u0641\u0631\u0647 \u0647\u0641\u062a\u200c\u0633\u06cc\u0646 \u0646\u0645\u0627\u062f \u062b\u0631\u0648\u062a\u060c \u0641\u0631\u0627\u0648\u0627\u0646\u06cc \u0648 \u0628\u0631\u06a9\u062a \u0645\u0627\u0644\u06cc \u062f\u0631 \u0633\u0627\u0644 \u0646\u0648 \u0627\u0633\u062a. \u062d\u0636\u0648\u0631 \u0633\u06a9\u0647 \u0628\u06cc\u0627\u0646\u06af\u0631 \u0622\u0631\u0632\u0648\u06cc \u062a\u0648\u0641\u06cc\u0642 \u0648 \u0631\u0648\u0646\u0642 \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0628\u0631\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0627\u0633\u062a. \u062f\u0631 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0627\u0632 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0647\u0627\u060c \u0628\u0632\u0631\u06af\u200c\u062a\u0631\u0647\u0627 \u0633\u06a9\u0647 \u0631\u0627 \u0628\u0647\u200c\u0639\u0646\u0648\u0627\u0646 \u0639\u06cc\u062f\u06cc \u0628\u0647 \u06a9\u0648\u0686\u06a9\u200c\u062a\u0631\u0647\u0627 \u0647\u062f\u06cc\u0647 \u0645\u06cc\u200c\u062f\u0647\u0646\u062f \u0648 \u0622\u0631\u0632\u0648\u06cc \u0641\u0631\u0627\u0648\u0627\u0646\u06cc \u0631\u0627 \u0628\u0627 \u0622\u0646\u0627\u0646 \u0642\u0633\u0645\u062a \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f.",
  "dormant_sizdah_bedar": "\u0627\u0645\u06cc\u062f\u0648\u0627\u0631\u06cc\u0645 \u0633\u06cc\u0632\u062f\u0647\u200c\u0628\u062f\u0631 \u062e\u0648\u0628\u06cc \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u06cc\u062f \u2014 \u0631\u0648\u0632 \u0633\u06cc\u0632\u062f\u0647\u0645 \u0646\u0648\u0631\u0648\u0632\u060c \u0631\u0648\u0632\u06cc \u06a9\u0647 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0647\u0627 \u0628\u0647 \u062f\u0627\u0645\u0646 \u0637\u0628\u06cc\u0639\u062a \u0645\u06cc\u200c\u0631\u0648\u0646\u062f \u0648 \u0633\u0628\u0632\u0647\u200c\u0647\u0627 \u0631\u0627 \u0628\u0647 \u0622\u0628 \u0631\u0648\u0627\u0646 \u0645\u06cc\u200c\u0633\u067e\u0627\u0631\u0646\u062f\u060c \u0646\u0645\u0627\u062f\u06cc \u0627\u0632 \u062a\u0627\u0632\u0647 \u0634\u062f\u0646 \u0632\u0646\u062f\u06af\u06cc.",
  "dormant_next_norouz": "\u0646\u0648\u0631\u0648\u0632 \u0622\u06cc\u0646\u062f\u0647",
  "dormant_next_countdown": "\u0634\u0645\u0627\u0631\u0634 \u0645\u0639\u06a9\u0648\u0633 \u062a\u0627 \u0646\u0648\u0631\u0648\u0632 \u0628\u0639\u062f\u06cc \u0628\u0647\u200c\u0632\u0648\u062f\u06cc \u0622\u063a\u0627\u0632 \u0645\u06cc\u200c\u0634\u0648\u062f.",
  "chat_title": "\u06af\u0641\u062a\u06af\u0648\u06cc \u0646\u0648\u0631\u0648\u0632\u06cc",
  "chat_sign_in": "\u0628\u0631\u0627\u06cc \u06af\u0641\u062a\u06af\u0648 \u0628\u0627 \u06af\u0648\u06af\u0644 \u0648\u0627\u0631\u062f \u0634\u0648\u06cc\u062f",
  "chat_sign_out": "\u062e\u0631\u0648\u062c",
  "chat_placeholder": "\u06cc\u06a9 \u067e\u06cc\u0627\u0645 \u0646\u0648\u0631\u0648\u0632\u06cc \u0628\u0641\u0631\u0633\u062a\u06cc\u062f\u2026",
  "chat_send": "\u0627\u0631\u0633\u0627\u0644",
  "chat_close": "\u0628\u0633\u062a\u0646 \u06af\u0641\u062a\u06af\u0648",
  "chat_open": "\u06af\u0641\u062a\u06af\u0648\u06cc \u0646\u0648\u0631\u0648\u0632\u06cc",
  "chat_error": "\u0627\u0631\u062a\u0628\u0627\u0637 \u0628\u0627 \u06af\u0641\u062a\u06af\u0648 \u0628\u0631\u0642\u0631\u0627\u0631 \u0646\u0634\u062f",
  "chat_empty": "\u0627\u0648\u0644\u06cc\u0646 \u06a9\u0633\u06cc \u0628\u0627\u0634\u06cc\u062f \u06a9\u0647 \u062a\u0628\u0631\u06cc\u06a9 \u0646\u0648\u0631\u0648\u0632 \u0645\u06cc\u200c\u0641\u0631\u0633\u062a\u062f!",
  "chat_already_sent": "\u067e\u06cc\u0627\u0645 \u0646\u0648\u0631\u0648\u0632\u06cc \u0634\u0645\u0627 \u0627\u0645\u0633\u0627\u0644 \u0641\u0631\u0633\u062a\u0627\u062f\u0647 \u0634\u062f \u2014 \u0633\u0627\u0644 \u062f\u06cc\u06af\u0631 \u0645\u06cc\u200c\u0628\u06cc\u0646\u06cc\u0645\u062a\u0627\u0646!"
}
